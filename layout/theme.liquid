<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="">
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Montserrat:wght@400;500;600;700;800&display=swap">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Montserrat:wght@400;500;600;700;800&display=swap" media="print" onload="this.media='all'">

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% else %}
      <meta name="description" content="Premium, science-backed One4Health™ Ashwagandha gummies. Specialists in clinically studied KSM-66® root extract, black pepper extract, and Vitamin D2 for maximum bioavailability, cortisol regulation, stress relief, and sleep optimization. 100% vegan.">
    {% endif %}

    <meta name="keywords" content="One4Health, ashwagandha gummies India, KSM-66 extract, black pepper extract, cortisol regulation, stress relief India, sleep optimization, vegan health supplements, adaptogens, hormone balance, focus gummies">
    <meta name="application-name" content="One4Health Wellness" />
    <meta name="apple-mobile-web-app-title" content="One4Health" />
    <meta name="geo.region" content="IN-UP" />
    <meta name="geo.placename" content="Lucknow" />
    <meta name="geo.position" content="26.8467;80.9462" />
    <meta name="ICBM" content="26.8467, 80.9462" />

    <!-- Google Search Console Verification -->
    <meta name="google-site-verification" content="TQO_Q5x3A4oqUTcxb-4z1EdHO0vpKyn7yAxwl185yI4" />
    <meta name="msvalidate.01" content="ADD_BING_VERIFICATION_TAG_HERE" />

    <!-- Google Analytics (GA4) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-L3GJXRQX63"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag('js', new Date());
      gtag('config', 'G-L3GJXRQX63');
    </script>

    <!-- Google Tag Manager: add GTM container ID here when ready -->

    <!-- Open Graph / Facebook -->
    {%- assign og_title = page_title | default: shop.name -%}
    {%- assign og_url = canonical_url | default: shop.url -%}
    {%- assign og_type = 'website' -%}
    {%- assign default_social_desc = 'Clean, science-backed Ashwagandha gummies for stress relief and better sleep. KSM-66® with Vitamin D2 & black pepper extract. Vegan, sugar-free, made in India.' -%}
    {%- assign og_description = page_description | default: shop.description | default: default_social_desc -%}
    
    {%- if template.name == 'product' -%}
      {%- assign og_type = 'product' -%}
      {%- if product.featured_media -%}
        {%- assign og_image = product.featured_media | image_url: width: 1200 -%}
      {%- else -%}
        {%- assign og_image = 'product_transparent.png' | asset_url -%}
      {%- endif -%}
    {%- elsif template.name == 'collection' -%}
      {%- if collection.image -%}
        {%- assign og_image = collection.image | image_url: width: 1200 -%}
      {%- else -%}
        {%- assign og_image = 'product_transparent.png' | asset_url -%}
      {%- endif -%}
    {%- else -%}
      {%- assign og_image = 'product_transparent.png' | asset_url -%}
    {%- endif -%}

    {%- if og_image contains '?' -%}
      {%- assign og_image_path = og_image | split: '?' | first -%}
    {%- else -%}
      {%- assign og_image_path = og_image -%}
    {%- endif -%}

    <meta property="og:site_name" content="{{ shop.name }}">
    <meta property="og:url" content="{{ og_url }}">
    <meta property="og:title" content="{{ og_title | escape }}">
    <meta property="og:type" content="{{ og_type }}">
    <meta property="og:description" content="{{ og_description | escape }}">
    <meta property="og:locale" content="en_IN">

    <meta property="og:image" content="https:{{ og_image }}">
    <meta property="og:image:secure_url" content="https:{{ og_image }}">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="1200">

    {%- if template.name == 'product' -%}
      <meta property="product:price:amount" content="{{ product.selected_or_first_available_variant.price | divided_by: 100.00 }}">
      <meta property="product:price:currency" content="{{ cart.currency.iso_code }}">
      <meta property="product:availability" content="{% if product.available %}in stock{% else %}out of stock{% endif %}">
    {%- endif -%}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ og_title | escape }}">
    <meta name="twitter:description" content="{{ og_description | escape }}">
    <meta name="twitter:image" content="https:{{ og_image }}">

    <!-- Structured Data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "One4Health™",
      "url": "{{ shop.url }}",
      "logo": "https:{{ 'logo_cropped.png' | asset_url }}",
      "description": "Premium wellness brand delivering science-backed Ashwagandha gummies. Specialists in KSM-66® technology, stress management, and sleep optimization.",
      "foundingDate": "2024",
      "knowsAbout": [
        "Ashwagandha",
        "KSM-66®",
        "Wellness Supplements",
        "Stress Relief",
        "black pepper extract",
        "Nutraceuticals"
      ],
      "sameAs": [
        "https://instagram.com/one4health",
        "https://twitter.com/one4health",
        "https://www.linkedin.com/company/one4health",
        "https://www.youtube.com/@one4health"
      ],
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+91 7767-968-079",
        "contactType": "customer service",
        "email": "info@one4health.com"
      },
      "founder": {
        "@type": "Person",
        "name": "One4Health™ Team"
      },
      "slogan": "Stay Calm. Stay Sharp."
    }
    </script>

    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "One4Health™",
      "url": "{{ shop.url }}",
      "potentialAction": {
        "@type": "SearchAction",
        "target": "{{ shop.url }}/search?q={search_term_string}",
        "query-input": "required name=search_term_string"
      }
    }
    </script>

    {%- if template.name == 'product' -%}
      <script type="application/ld+json">
      {
        "@context": "https://schema.org/",
        "@type": "Product",
        "name": {{ product.title | json }},
        "url": {{ shop.url | append: product.url | json }},
        "image": [
          {{ product.featured_media | image_url: width: 1024 | prepend: "https:" | json }}
        ],
        "description": {{ product.description | strip_html | json }},
        "sku": {{ product.selected_or_first_available_variant.sku | json }},
        "brand": {
          "@type": "Brand",
          "name": "One4Health™"
        },
        "material": "KSM-66® Ashwagandha",
        "additionalProperty": [
          {
            "@type": "PropertyValue",
            "name": "Dietary Preference",
            "value": "Vegan, Sugar-Free, Gelatin-Free, Non-GMO"
          },
          {
            "@type": "PropertyValue",
            "name": "Special Ingredients",
            "value": "black pepper extract, Vitamin D2"
          }
        ],
        "offers": {
          "@type": "Offer",
          "url": {{ shop.url | append: product.selected_or_first_available_variant.url | json }},
          "priceCurrency": {{ cart.currency.iso_code | json }},
          "price": {{ product.selected_or_first_available_variant.price | divided_by: 100.0 | json }},
          "priceValidUntil": "2026-12-31",
          "availability": "https://schema.org/{% if product.available %}InStock{% else %}OutOfStock{% endif %}",
          "seller": {
            "@type": "Organization",
            "name": "One4Health™"
          }
        }
      }
      </script>
    {%- endif -%}

    <!-- Robots -->
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">

    <!-- Structured Data: Breadcrumbs -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "{{ shop.url }}"
        }
        {%- if template.name == 'product' -%}
        ,{
          "@type": "ListItem",
          "position": 2,
          "name": "{{ product.title }}",
          "item": "{{ shop.url }}{{ product.url }}"
        }
        {%- elsif template.name == 'collection' -%}
        ,{
          "@type": "ListItem",
          "position": 2,
          "name": "{{ collection.title }}",
          "item": "{{ shop.url }}{{ collection.url }}"
        }
        {%- elsif template.name == 'page' -%}
        ,{
          "@type": "ListItem",
          "position": 2,
          "name": "{{ page.title }}",
          "item": "{{ shop.url }}{{ page.url }}"
        }
        {%- endif -%}
      ]
    }
    </script>

    <script>
      window.ShopifyAssetsUrl = "{{ 'bundle.js' | asset_url | split: 'bundle.js' | first }}";
      
      window.ShopifyData = {
        product: {{ product | json }},
        all_products: {
          {% for p in collections.all.products limit: 20 %}
            "{{ p.handle }}": {{ p | json }}{% unless forloop.last %},{% endunless %}
          {% endfor %}
        },
        cart: {{ cart | json }},
        routes: {
          root: "{{ routes.root_url }}",
          cart_add_url: "{{ routes.cart_add_url }}",
          cart_change_url: "{{ routes.cart_change_url }}",
          cart_update_url: "{{ routes.cart_update_url }}",
          cart_url: "{{ routes.cart_url }}",
          predictive_search_url: "{{ routes.predictive_search_url }}"
        }
      };
    </script>

    {{ content_for_header }}

    {{ 'bundle.css' | asset_url | stylesheet_tag }}
  </head>

  <body class="gradient">
    <!-- Google Tag Manager noscript: add GTM container ID here when ready -->

    <div id="root"></div>

    {{ content_for_layout }}

    <script type="module" src="{{ 'bundle.js' | asset_url }}"></script>
  </body>
</html>
